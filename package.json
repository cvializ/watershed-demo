  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "@types/three": "^0.185.0",
    "knip": "^6.23.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^0.15.0",
    "playwright": "^1.61.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.0"
  }
}
